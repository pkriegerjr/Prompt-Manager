# ============================================================
#  ARS PROMPT — Exemplo de configuração
#  Copie este arquivo para "config.env" e preencha os valores
#  Este arquivo PODE ser enviado ao GitHub (não tem dados reais)
# ============================================================

# Banco de dados MySQL
DB_URL=jdbc:mysql://localhost:3306/ars_database?useSSL=false&serverTimezone=America/Sao_Paulo&characterEncoding=UTF-8
DB_USER=root
DB_PASS=

# Email SMTP (Gmail)
# Para gerar o SMTP_PASS: myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=SEU_EMAIL@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# URL base do front-end (onde estão os HTMLs)
BASE_URL=http://localhost:8080/Ars-Promptum/BackEnd/src/Home%20Page
