# Copie este arquivo para config.env e preencha os valores do seu ambiente local.
# Nunca publique o config.env real.

DB_URL=jdbc:mysql://localhost:3306/ars_database?useSSL=false&serverTimezone=America/Sao_Paulo&characterEncoding=UTF-8
DB_USER=root
DB_PASS=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app

BASE_URL=http://localhost:8081/pages

# Use uma chave longa e unica no seu ambiente local.
SESSION_SECRET=troque-por-uma-chave-local-grande-e-aleatoria
SESSION_TTL_HOURS=8
